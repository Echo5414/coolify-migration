# Copy this file to .env and fill in the real values.
# Do not commit .env. It may contain hostnames, usernames, key paths, and domains.

# Source server: the current Contabo Coolify host.
SOURCE_HOST=
SOURCE_USER=root
SOURCE_PORT=22
SOURCE_SSH_KEY=~/.ssh/coolify_migration
# Optional one-time bootstrap only. Prefer key auth for all migration phases.
# scripts/bootstrap-source-key.py uses this without putting the password in a
# process argument, then normal scripts should use SOURCE_SSH_KEY.
SOURCE_PASSWORD=

# Destination server: the new Hetzner host.
DEST_HOST=
DEST_USER=root
DEST_PORT=22
DEST_SSH_KEY=~/.ssh/coolify_migration

# Coolify paths and version.
# Keep COOLIFY_VERSION pinned to the source version for the migration window.
COOLIFY_DATA_DIR=/data/coolify
COOLIFY_VERSION=

# Remote working directory used on both servers for manifests, dumps, and archives.
MIGRATION_WORKDIR=/root/coolify-migration

# Local artifacts are written here by read-only inventory/preflight scripts.
LOCAL_ARTIFACT_DIR=./artifacts

# Backup behavior.
# true is the safe default for a byte-level Docker volume snapshot.
STOP_DOCKER_FOR_BACKUP=true

# Cutover behavior. When true, backup-source.sh leaves source Docker stopped
# after creating the archive so Contabo cannot accept writes while Hetzner is
# being restored and tested.
KEEP_SOURCE_DOCKER_STOPPED=false

# Best-effort logical dumps for containers that expose pg_dump or mysqldump
# with standard POSTGRES_* / MYSQL_* / MARIADB_* environment variables.
RUN_DB_DUMPS=true

# Extra bind mount paths outside /data/coolify to include in the backup.
# Colon-separated absolute paths. Leave empty until inventory has confirmed them.
# Example: EXTRA_BIND_PATHS=/srv/uploads:/opt/my-app/storage
EXTRA_BIND_PATHS=

# Do not migrate root authorized_keys by default. Coolify SSH keys live under
# /data/coolify/ssh/keys and are included with COOLIFY_DATA_DIR.
MERGE_ROOT_AUTHORIZED_KEYS=false

# Destination restore guardrails.
# Restore requires stopping Docker on the destination. This may interrupt any
# Docker-managed Counter-Strike server.
ALLOW_DESTINATION_DOCKER_STOP=false

# If /data/coolify already exists on the destination, fail by default.
# Set true only after confirming the existing destination state is disposable.
MOVE_EXISTING_DEST_COOLIFY=false

# The restore script refuses to install latest Coolify unless either
# COOLIFY_VERSION is set or this is explicitly true.
ALLOW_LATEST_COOLIFY=false

# Verification does not print container logs by default because logs can contain
# tokens, passwords, or app secrets. Set true only for targeted debugging.
SHOW_VERIFY_LOGS=false

# Domains used for hosts-file test instructions and DNS cutover notes.
# Space-separated list.
DOMAINS=
NEW_SERVER_IPV4=
NEW_SERVER_IPV6=
